# ===== CHỌN NGUỒN KỊCH BẢN (text) =====
# "google" = Gemini cloud (free tier, KHÔNG dùng GPU). Mặc định.
# "local"  = Ollama (dùng GPU NVIDIA).
AI_PROVIDER=google

# ===== CHỌN NGUỒN ẢNH =====
# "pollinations" = Flux miễn phí qua Pollinations.ai (KHÔNG cần key, KHÔNG dùng GPU). Mặc định.
# "google"       = Imagen của Google (CHẤT lượng cao nhưng cần gói TRẢ PHÍ).
# "local"        = ComfyUI/Flux trên GPU máy bạn.
IMAGE_PROVIDER=pollinations

# ===== GOOGLE GEMINI (khi AI_PROVIDER=google) =====
# Lấy key FREE tại: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza_dán_key_vào_đây
GEMINI_TEXT_MODEL=gemini-2.5-flash
# Chỉ dùng khi IMAGE_PROVIDER=google (cần trả phí):
GEMINI_IMAGE_MODEL=imagen-4.0-generate-001

# ===== POLLINATIONS (khi IMAGE_PROVIDER=pollinations) =====
POLLINATIONS_MODEL=flux

# ===== CẤU HÌNH LOCAL (khi AI_PROVIDER=local) =====
# Tất cả đều có giá trị mặc định trong code. Chỉ cần đổi nếu bạn chạy khác cổng/model.
# Sao chép file này thành .env.local nếu muốn ghi đè.

# --- Kịch bản: Ollama (LLM local) ---
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b

# --- Giọng đọc: Edge-TTS (Python) ---
PYTHON_BIN=python
# Giọng mặc định (chọn được trên giao diện; biến này chỉ là fallback)
# EN: en-US-GuyNeural (nam) | en-US-JennyNeural (nữ) | en-GB-RyanNeural (nam UK)
# VN: vi-VN-NamMinhNeural (nam) | vi-VN-HoaiMyNeural (nữ)
EDGE_TTS_VOICE=en-US-GuyNeural
# Tốc độ đọc mặc định (UI ghi đè): "-12%" chậm | "+0%" thường | "+15%" nhanh
EDGE_TTS_RATE=+0%

# --- FFmpeg (chỉ cần nếu KHÔNG nằm trong PATH) ---
# FFMPEG_BIN=ffmpeg
# FFPROBE_BIN=ffprobe

# --- Sinh ảnh: ComfyUI + Flux.1-schnell (GPU NVIDIA) ---
COMFYUI_HOST=http://127.0.0.1:8188
COMFYUI_FLUX_CKPT=flux1-schnell-fp8.safetensors
